APP_NAME="Crypto Investor Dashboard API"
ENVIRONMENT=local
DEBUG=false
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/crypto_dashboard
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optional provider keys. The app works without these and falls back safely.
COINGECKO_API_KEY=
CRYPTOPANIC_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
