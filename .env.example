APP_NAME="Crypto Investor Dashboard API"
ENVIRONMENT=local
DEBUG=false
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/crypto_dashboard
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Optional provider keys. The app works without these and falls back safely.
COINGECKO_API_KEY=
CRYPTOPANIC_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
